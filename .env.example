# URL origin Laravel API (tanpa trailing slash), contoh: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Midtrans Snap (client key sama seperti di dashboard Midtrans; sandbox vs production)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
# Opsional — default sandbox
NEXT_PUBLIC_MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js
